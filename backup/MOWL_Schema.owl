        <rdfs:comment xml:lang="en">Validity end date</rdfs:comment>
        <rdfs:label xml:lang="en">validUntil</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mowl#venue -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#venue">
