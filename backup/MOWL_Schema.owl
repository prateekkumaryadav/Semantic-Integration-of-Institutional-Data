        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Department"/>
        <rdfs:comment xml:lang="en">Program is offered by a department</rdfs:comment>
        <rdfs:label xml:lang="en">offeredBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#offersProgram -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#offersProgram">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Program"/>
        <rdfs:comment xml:lang="en">Department/Institution offers a program</rdfs:comment>
        <rdfs:label xml:lang="en">offersProgram</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#organizedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#organizedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Event"/>
        <rdfs:comment xml:lang="en">Event is organized by an entity</rdfs:comment>
        <rdfs:label xml:lang="en">organizedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#organizesEvent -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#organizesEvent">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Event"/>
        <rdfs:comment xml:lang="en">Entity organizes an event</rdfs:comment>
        <rdfs:label xml:lang="en">organizesEvent</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#partOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#partOf">
