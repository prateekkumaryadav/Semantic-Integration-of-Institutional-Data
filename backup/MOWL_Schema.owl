    </rdfs:comment>
        <rdfs:label xml:lang="en">Sports Facility</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Staff -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Staff">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Person"/>
        <rdfs:comment xml:lang="en">
