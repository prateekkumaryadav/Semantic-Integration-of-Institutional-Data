    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mowl#totalSeats -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#totalSeats">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Total number of seats/intake capacity</rdfs:comment>
