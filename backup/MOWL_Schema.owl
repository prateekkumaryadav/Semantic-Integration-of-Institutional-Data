    </rdfs:comment>
        <rdfs:label xml:lang="en">Student Club</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#TechnicalClub -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#TechnicalClub">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#StudentClub"/>
        <rdfs:comment xml:lang="en">
      A technical or academic club focused on specific domains.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Technical Club</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#UndergraduateProgram -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#UndergraduateProgram">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Program"/>
