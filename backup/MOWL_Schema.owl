    <!-- http://www.semanticweb.org/mowl#AcademicFacility -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#AcademicFacility">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Facility"/>
        <rdfs:comment xml:lang="en">
      Academic facilities like libraries, labs, classrooms, lecture halls, etc.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Academic Facility</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Accreditation -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Accreditation">
        <rdfs:comment xml:lang="en">
      An accreditation, certification, or ranking received by the institution or programs.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Accreditation</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Alumni -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Alumni">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Person"/>
        <rdfs:comment xml:lang="en">
      A former student who has graduated from the institution.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Alumni</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Award -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Award">
        <rdfs:comment xml:lang="en">
      Awards or recognitions received by the institution, faculty, or students.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Award</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Conference -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Conference">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Event"/>
        <rdfs:comment xml:lang="en">
      An academic or professional conference.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Conference</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Course -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Course">
        <rdfs:comment xml:lang="en">
      An individual course, subject, or module within a program.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Course</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#CulturalClub -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#CulturalClub">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#StudentClub"/>
        <rdfs:comment xml:lang="en">
      A cultural, arts, or entertainment club.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Cultural Club</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Department -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Department">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Institution"/>
        <rdfs:comment xml:lang="en">
      An academic or administrative department within an institution.
      Departments offer programs, employ faculty, and conduct research.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Department</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#DiplomaProgram -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#DiplomaProgram">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Program"/>
        <rdfs:comment xml:lang="en">
      A diploma or certificate program.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Diploma Program</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#DoctoralProgram -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#DoctoralProgram">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Program"/>
        <rdfs:comment xml:lang="en">
      A doctoral or Ph.D. level research program.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Doctoral Program</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Event -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Event">
        <rdfs:comment xml:lang="en">
      An event, conference, workshop, seminar, or activity organized by or at the institution.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Event</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Facility -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Facility">
        <rdfs:comment xml:lang="en">
      A physical or digital facility available at the institution.
      Base class for all facility types.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Facility</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Faculty -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Faculty">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Person"/>
        <rdfs:comment xml:lang="en">
      A faculty member, professor, or teaching staff at the institution.
      Includes all academic ranks: Professor, Associate Professor, Assistant Professor, Lecturer, etc.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Faculty Member</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#FoodFacility -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#FoodFacility">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Facility"/>
        <rdfs:comment xml:lang="en">
      Food and dining facilities like cafeterias, canteens, mess halls, etc.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Food Facility</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#IndustryPartner -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#IndustryPartner">
        <rdfs:comment xml:lang="en">
      An industry partner collaborating with the institution for research,
      funding, training, or recruitment.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Industry Partner</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#InnovationFacility -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#InnovationFacility">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Facility"/>
        <rdfs:comment xml:lang="en">
      Innovation and entrepreneurship facilities like incubators, makerspaces, fab labs, etc.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Innovation Facility</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Institution -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Institution">
        <rdfs:comment xml:lang="en">
      An academic institution such as a university, college, or research institute.
      This is the top-level entity representing the entire organization.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Institution</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Internship -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Internship">
        <rdfs:comment xml:lang="en">
      An internship opportunity or program offered to students.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Internship</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#MedicalFacility -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#MedicalFacility">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Facility"/>
        <rdfs:comment xml:lang="en">
      Medical and health facilities like clinics, hospitals, wellness centers, etc.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Medical Facility</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Patent -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Patent">
        <rdfs:comment xml:lang="en">
      A patent filed or granted to faculty or the institution.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Patent</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Person -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Person">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment xml:lang="en">
      A person associated with the institution. Base class for all human entities.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Person</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Placement -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Placement">
        <rdfs:comment xml:lang="en">
      Placement statistics and records for a given academic year.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Placement Record</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#PostgraduateProgram -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#PostgraduateProgram">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Program"/>
        <rdfs:comment xml:lang="en">
      A master&apos;s level academic program (M.Tech, M.Sc, MBA, etc.).
    </rdfs:comment>
        <rdfs:label xml:lang="en">Postgraduate Program</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Program -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Program">
        <rdfs:comment xml:lang="en">
      An academic program or degree program offered by the institution.
      Base class for all program types.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Academic Program</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Publication -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Publication">
        <rdfs:comment xml:lang="en">
      A research publication such as a journal article, conference paper, book chapter, etc.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Publication</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Ranking -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Ranking">
        <rdfs:comment xml:lang="en">
      Rankings from national or international ranking bodies.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Ranking</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Recruiter -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Recruiter">
        <rdfs:comment xml:lang="en">
      A company or organization that recruits students from the institution.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Recruiter/Company</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#ResearchCentre -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#ResearchCentre">
        <rdfs:comment xml:lang="en">
      A research center or institute focused on specific research domains.
      Larger organizational unit than a lab, may contain multiple labs.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Research Centre</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#ResearchLab -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#ResearchLab">
        <rdfs:comment xml:lang="en">
      A research laboratory, group, or team conducting research in specific areas.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Research Laboratory</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#ResearchProject -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#ResearchProject">
        <rdfs:comment xml:lang="en">
      A funded or ongoing research project with specific objectives and timeline.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Research Project</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#ResidentialFacility -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#ResidentialFacility">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Facility"/>
        <rdfs:comment xml:lang="en">
      Residential facilities like hostels, dormitories, guest houses, etc.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Residential Facility</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#School -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#School">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Institution"/>
        <rdfs:comment xml:lang="en">
      A school or college within a larger institution, typically comprising multiple departments.
    </rdfs:comment>
        <rdfs:label xml:lang="en">School</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#Seminar -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#Seminar">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Event"/>
        <rdfs:comment xml:lang="en">
      A seminar or guest lecture.
    </rdfs:comment>
        <rdfs:label xml:lang="en">Seminar</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#SportsFacility -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#SportsFacility">
