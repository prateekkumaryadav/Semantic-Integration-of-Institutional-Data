        <rdfs:label xml:lang="en">syllabus</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mowl#title -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#title">
