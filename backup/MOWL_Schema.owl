        <rdfs:label xml:lang="en">Student</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/mowl#StudentClub -->

    <owl:Class rdf:about="http://www.semanticweb.org/mowl#StudentClub">
        <rdfs:comment xml:lang="en">
