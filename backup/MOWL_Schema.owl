        <rdfs:label xml:lang="en">venue</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/mowl#vision -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#vision">
