<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/mowl#"
     xml:base="http://www.semanticweb.org/mowl"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:mowl="http://www.semanticweb.org/mowl#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/mowl">
        <owl:imports rdf:resource="http://www.iiitb.ac.in/ontology/IIITB#"/>
        <owl:imports rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#"/>
        <owl:imports rdf:resource="http://www.semanticweb.org/iiith"/>
        <owl:imports rdf:resource="http://www.semanticweb.org/mowl/mapping"/>
        <rdfs:comment xml:lang="en">A comprehensive Master OWL schema designed to integrate and represent all aspects of an ideal academic institution. This schema unifies the ontologies of IIIT Hyderabad, IIIT Bangalore, and IIIT Delhi, covering institutional structure, academics, research, placements, facilities, accreditations, events, awards, student life, and industry partnerships.</rdfs:comment>
        <rdfs:label xml:lang="en">Master OWL (MOWL) Schema for Academic Institutions</rdfs:label>
        <owl:versionInfo>2.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2001/XMLSchema#date -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#gYear -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#gYear"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/mowl#accreditedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#accreditedBy">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Accreditation"/>
        <rdfs:comment xml:lang="en">Institution/Program is accredited by a body</rdfs:comment>
        <rdfs:label xml:lang="en">accreditedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#advisedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#advisedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Student"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Faculty"/>
        <rdfs:comment xml:lang="en">Student is advised by a faculty member</rdfs:comment>
        <rdfs:label xml:lang="en">advisedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#advises -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#advises">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Faculty"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Student"/>
        <rdfs:comment xml:lang="en">Faculty advises a student</rdfs:comment>
        <rdfs:label xml:lang="en">advises</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#authored -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#authored">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Person"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Publication"/>
        <rdfs:comment xml:lang="en">Person authored a publication</rdfs:comment>
        <rdfs:label xml:lang="en">authored</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#authoredBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#authoredBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Publication"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Person"/>
        <rdfs:comment xml:lang="en">Publication authored by a person</rdfs:comment>
        <rdfs:label xml:lang="en">authoredBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#belongsToDepartment -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#belongsToDepartment">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Person"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Department"/>
        <rdfs:comment xml:lang="en">Faculty/Person belongs to a department</rdfs:comment>
        <rdfs:label xml:lang="en">belongsToDepartment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#belongsToInstitution -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#belongsToInstitution">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/mowl#hasDepartment"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Institution"/>
        <rdfs:comment xml:lang="en">Entity belongs to an institution</rdfs:comment>
        <rdfs:label xml:lang="en">belongsToInstitution</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#coPrincipalInvestigator -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#coPrincipalInvestigator">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#ResearchProject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Faculty"/>
        <rdfs:comment xml:lang="en">Co-principal investigator of a project</rdfs:comment>
        <rdfs:label xml:lang="en">coPrincipalInvestigator</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#collaboratesWith -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#collaboratesWith">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Person"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Person"/>
        <rdfs:comment xml:lang="en">Person collaborates with another person</rdfs:comment>
        <rdfs:label xml:lang="en">collaboratesWith</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#deanOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#deanOf">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Faculty"/>
        <rdfs:comment xml:lang="en">Dean of a school or faculty</rdfs:comment>
        <rdfs:label xml:lang="en">deanOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#directedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#directedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#ResearchCentre"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Faculty"/>
        <rdfs:comment xml:lang="en">Research centre is directed by a faculty member</rdfs:comment>
        <rdfs:label xml:lang="en">directedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#directorOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#directorOf">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Faculty"/>
        <rdfs:comment xml:lang="en">Director of the institution or research centre</rdfs:comment>
        <rdfs:label xml:lang="en">directorOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#enrolledIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#enrolledIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Student"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Program"/>
        <rdfs:comment xml:lang="en">Student is enrolled in a program</rdfs:comment>
        <rdfs:label xml:lang="en">enrolledIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#facultyAdvisor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#facultyAdvisor">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Faculty"/>
        <rdfs:comment xml:lang="en">Faculty advisor of a club or organization</rdfs:comment>
        <rdfs:label xml:lang="en">facultyAdvisor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#fundedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#fundedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#ResearchProject"/>
        <rdfs:comment xml:lang="en">Project is funded by an organization</rdfs:comment>
        <rdfs:label xml:lang="en">fundedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#hasCentre -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#hasCentre">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#ResearchCentre"/>
        <rdfs:comment xml:lang="en">Institution has a research centre</rdfs:comment>
        <rdfs:label xml:lang="en">hasCentre</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#hasClub -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#hasClub">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Institution"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#StudentClub"/>
        <rdfs:comment xml:lang="en">Institution has a student club</rdfs:comment>
        <rdfs:label xml:lang="en">hasClub</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#hasCourse -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#hasCourse">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Course"/>
        <rdfs:comment xml:lang="en">Program/Department has a course</rdfs:comment>
        <rdfs:label xml:lang="en">hasCourse</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#hasDepartment -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#hasDepartment">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Institution"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Department"/>
        <rdfs:comment xml:lang="en">Institution has a department</rdfs:comment>
        <rdfs:label xml:lang="en">hasDepartment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#hasFacility -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#hasFacility">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Institution"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Facility"/>
        <rdfs:comment xml:lang="en">Institution has a facility</rdfs:comment>
        <rdfs:label xml:lang="en">hasFacility</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#hasFaculty -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#hasFaculty">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Faculty"/>
        <rdfs:comment xml:lang="en">Institution/Department has a faculty member</rdfs:comment>
        <rdfs:label xml:lang="en">hasFaculty</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#hasIndustryPartner -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#hasIndustryPartner">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Institution"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#IndustryPartner"/>
        <rdfs:comment xml:lang="en">Institution has an industry partner</rdfs:comment>
        <rdfs:label xml:lang="en">hasIndustryPartner</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#hasLab -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#hasLab">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#ResearchLab"/>
        <rdfs:comment xml:lang="en">Department/Institution has a research lab</rdfs:comment>
        <rdfs:label xml:lang="en">hasLab</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#hasMember -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#hasMember">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Person"/>
        <rdfs:comment xml:lang="en">Lab/Centre has a member</rdfs:comment>
        <rdfs:label xml:lang="en">hasMember</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#hasPart -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#hasPart">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/mowl#partOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:comment xml:lang="en">Entity has a part</rdfs:comment>
        <rdfs:label xml:lang="en">hasPart</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#hasPlacementRecord -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#hasPlacementRecord">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Placement"/>
        <rdfs:comment xml:lang="en">Institution/Department has a placement record</rdfs:comment>
        <rdfs:label xml:lang="en">hasPlacementRecord</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#hasProject -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#hasProject">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#ResearchProject"/>
        <rdfs:comment xml:lang="en">Lab/Faculty has a research project</rdfs:comment>
        <rdfs:label xml:lang="en">hasProject</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#hasSchool -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#hasSchool">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Institution"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#School"/>
        <rdfs:comment xml:lang="en">Institution has a school/college</rdfs:comment>
        <rdfs:label xml:lang="en">hasSchool</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#hasStudent -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#hasStudent">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Student"/>
        <rdfs:comment xml:lang="en">Program/Department has a student</rdfs:comment>
        <rdfs:label xml:lang="en">hasStudent</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#headOfDepartment -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#headOfDepartment">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Department"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Faculty"/>
        <rdfs:comment xml:lang="en">Head/Chair of a department</rdfs:comment>
        <rdfs:label xml:lang="en">headOfDepartment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#headsLab -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#headsLab">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Faculty"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#ResearchLab"/>
        <rdfs:comment xml:lang="en">Faculty heads a research lab</rdfs:comment>
        <rdfs:label xml:lang="en">headsLab</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#locatedAt -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#locatedAt">
        <rdfs:comment xml:lang="en">Entity is located at an institution or facility</rdfs:comment>
        <rdfs:label xml:lang="en">locatedAt</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#memberOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#memberOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Person"/>
        <rdfs:comment xml:lang="en">Person is a member of a lab or centre</rdfs:comment>
        <rdfs:label xml:lang="en">memberOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#offeredBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#offeredBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Program"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Department"/>
        <rdfs:comment xml:lang="en">Program is offered by a department</rdfs:comment>
        <rdfs:label xml:lang="en">offeredBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#offersProgram -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#offersProgram">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Program"/>
        <rdfs:comment xml:lang="en">Department/Institution offers a program</rdfs:comment>
        <rdfs:label xml:lang="en">offersProgram</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#organizedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#organizedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Event"/>
        <rdfs:comment xml:lang="en">Event is organized by an entity</rdfs:comment>
        <rdfs:label xml:lang="en">organizedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#organizesEvent -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#organizesEvent">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Event"/>
        <rdfs:comment xml:lang="en">Entity organizes an event</rdfs:comment>
        <rdfs:label xml:lang="en">organizesEvent</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#partOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#partOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:comment xml:lang="en">Entity is part of another entity</rdfs:comment>
        <rdfs:label xml:lang="en">partOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#partOfProgram -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#partOfProgram">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Course"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Program"/>
        <rdfs:comment xml:lang="en">Course is part of a program</rdfs:comment>
        <rdfs:label xml:lang="en">partOfProgram</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#participatesIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#participatesIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Person"/>
        <rdfs:comment xml:lang="en">Person participates in an event or activity</rdfs:comment>
        <rdfs:label xml:lang="en">participatesIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#partnersWithInstitution -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#partnersWithInstitution">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#IndustryPartner"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Institution"/>
        <rdfs:comment xml:lang="en">Industry partner collaborates with institution</rdfs:comment>
        <rdfs:label xml:lang="en">partnersWithInstitution</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#placedAt -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#placedAt">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Student"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Recruiter"/>
        <rdfs:comment xml:lang="en">Student was placed at a company</rdfs:comment>
        <rdfs:label xml:lang="en">placedAt</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#presidentOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#presidentOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Student"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#StudentClub"/>
        <rdfs:comment xml:lang="en">Student is president of a club</rdfs:comment>
        <rdfs:label xml:lang="en">presidentOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#principalInvestigator -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#principalInvestigator">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#ResearchProject"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Faculty"/>
        <rdfs:comment xml:lang="en">Principal investigator of a project</rdfs:comment>
        <rdfs:label xml:lang="en">principalInvestigator</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#rankedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#rankedBy">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Ranking"/>
        <rdfs:comment xml:lang="en">Institution is ranked by a ranking body</rdfs:comment>
        <rdfs:label xml:lang="en">rankedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#receivedAward -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#receivedAward">
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Award"/>
        <rdfs:comment xml:lang="en">Entity received an award</rdfs:comment>
        <rdfs:label xml:lang="en">receivedAward</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#recruitedFrom -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#recruitedFrom">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Recruiter"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Institution"/>
        <rdfs:comment xml:lang="en">Company recruited from an institution</rdfs:comment>
        <rdfs:label xml:lang="en">recruitedFrom</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/mowl#relatedTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#relatedTo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:comment xml:lang="en">Generic relationship between entities</rdfs:comment>
        <rdfs:label xml:lang="en">relatedTo</rdfs:label>
