<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
  xmlns:rdf  ="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:rdfs ="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:owl  ="http://www.w3.org/2002/07/owl#"
  xmlns:xsd  ="http://www.w3.org/2001/XMLSchema#"
  xmlns:dc   ="http://purl.org/dc/elements/1.1/"
  xmlns:foaf ="http://xmlns.com/foaf/0.1/"
  xmlns:D    ="http://www.iiitd.ac.in/ontology/IIITD#"
  xml:base   ="http://www.iiitd.ac.in/ontology/IIITD#">

  <!-- ════════════ ONTOLOGY HEADER ════════════ -->
  <owl:Ontology rdf:about="http://www.iiitd.ac.in/ontology/IIITD#">
    <dc:title>IIITD University Ontology</dc:title>
    <dc:description>Comprehensive OWL ontology for IIITD covering faculty, programs, departments, research, placements and facilities. Integrable into Master University OWL.</dc:description>
    <dc:creator>IIITD HTML Parser v2.0 — RDF/XML Edition</dc:creator>
    <dc:date>2025</dc:date>
    <owl:versionInfo>2.0.0</owl:versionInfo>
  </owl:Ontology>

  <!-- ════════════════════════════════════════
       OWL CLASSES
  ════════════════════════════════════════ -->
  <owl:Class rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_University">
    <rdfs:label xml:lang="en">D_University</rdfs:label>
    <rdfs:comment xml:lang="en">Represents a university or academic institution.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Department">
    <rdfs:label xml:lang="en">D_Department</rdfs:label>
    <rdfs:comment xml:lang="en">An academic department within a university.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_University"/>
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Faculty">
    <rdfs:label xml:lang="en">D_FacultyMember</rdfs:label>
    <rdfs:comment xml:lang="en">A faculty member of the university.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Program">
    <rdfs:label xml:lang="en">D_AcademicProgram</rdfs:label>
    <rdfs:comment xml:lang="en">An academic program offered by a department.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_UGProgram">
    <rdfs:label xml:lang="en">D_UGProgram</rdfs:label>
    <rdfs:comment xml:lang="en">A Bachelor-level academic program.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Program"/>
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_PGProgram">
    <rdfs:label xml:lang="en">D_PGProgram</rdfs:label>
    <rdfs:comment xml:lang="en">A Master-level academic program.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Program"/>
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_DoctoralProgram">
    <rdfs:label xml:lang="en">D_DoctoralProgram</rdfs:label>
    <rdfs:comment xml:lang="en">A Ph.D level research program.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Program"/>
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Course">
    <rdfs:label xml:lang="en">D_Course</rdfs:label>
    <rdfs:comment xml:lang="en">An individual course or subject offered by a department.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_ResearchLab">
    <rdfs:label xml:lang="en">D_ResearchLab</rdfs:label>
    <rdfs:comment xml:lang="en">A research group or laboratory within the university.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Publication">
    <rdfs:label xml:lang="en">D_Publication</rdfs:label>
    <rdfs:comment xml:lang="en">A research paper or publication authored by faculty.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Placement">
    <rdfs:label xml:lang="en">D_Placement</rdfs:label>
    <rdfs:comment xml:lang="en">Annual placement statistics of the university.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Recruiter">
    <rdfs:label xml:lang="en">D_Recruiter</rdfs:label>
    <rdfs:comment xml:lang="en">A company that recruits students from the university.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Accreditation">
    <rdfs:label xml:lang="en">D_Accreditation</rdfs:label>
    <rdfs:comment xml:lang="en">An accreditation or ranking received by the university.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Facility">
    <rdfs:label xml:lang="en">D_Facility</rdfs:label>
    <rdfs:comment xml:lang="en">A physical or digital facility available on campus.</rdfs:comment>
    
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Student">
    <rdfs:label xml:lang="en">D_Student</rdfs:label>
    <rdfs:comment xml:lang="en">A student enrolled in a program at the university.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
  </owl:Class>
  <owl:Class rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Award">
    <rdfs:label xml:lang="en">D_Award</rdfs:label>
    <rdfs:comment xml:lang="en">An award or recognition received by faculty or the institution.</rdfs:comment>
    
  </owl:Class>

  <!-- ════════════════════════════════════════
       DATA PROPERTIES
  ════════════════════════════════════════ -->
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasName">
    <rdfs:label xml:lang="en">D_hasName</rdfs:label>
    <rdfs:comment xml:lang="en">The full name of the entity.</rdfs:comment>
    <rdfs:domain>
      <owl:Class><owl:unionOf rdf:parseType="Collection"><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_University"/><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Department"/><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Faculty"/><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Program"/><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Course"/><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_ResearchLab"/><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Recruiter"/><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Facility"/><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Student"/></owl:unionOf></owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasShortName">
    <rdfs:label xml:lang="en">D_hasShortName</rdfs:label>
    <rdfs:comment xml:lang="en">Abbreviation or short name.</rdfs:comment>
    <rdfs:domain>
      <owl:Class><owl:unionOf rdf:parseType="Collection"><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_University"/><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Department"/><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Program"/></owl:unionOf></owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasEstablishedYear">
    <rdfs:label xml:lang="en">D_hasEstablishedYear</rdfs:label>
    <rdfs:comment xml:lang="en">Year the university was established.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasUniversityType">
    <rdfs:label xml:lang="en">D_hasUniversityType</rdfs:label>
    <rdfs:comment xml:lang="en">Type such as Deemed, Central, State.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasLocation">
    <rdfs:label xml:lang="en">D_hasLocation</rdfs:label>
    <rdfs:comment xml:lang="en">Physical address of the entity.</rdfs:comment>
    <rdfs:domain>
      <owl:Class><owl:unionOf rdf:parseType="Collection"><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_University"/><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Facility"/></owl:unionOf></owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasWebsite">
    <rdfs:label xml:lang="en">D_hasWebsite</rdfs:label>
    <rdfs:comment xml:lang="en">Website of the university.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasEmail">
    <rdfs:label xml:lang="en">D_hasEmail</rdfs:label>
    <rdfs:comment xml:lang="en">Official email address.</rdfs:comment>
    <rdfs:domain>
      <owl:Class><owl:unionOf rdf:parseType="Collection"><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_University"/><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Faculty"/><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Department"/></owl:unionOf></owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasPhone">
    <rdfs:label xml:lang="en">D_hasPhone</rdfs:label>
    <rdfs:comment xml:lang="en">Contact phone number.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasTotalStudents">
    <rdfs:label xml:lang="en">D_hasTotalStudents</rdfs:label>
    <rdfs:comment xml:lang="en">Total number of enrolled students.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasTotalFaculty">
    <rdfs:label xml:lang="en">D_hasTotalFaculty</rdfs:label>
    <rdfs:comment xml:lang="en">Total number of faculty members.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasCampusArea">
    <rdfs:label xml:lang="en">D_hasCampusArea</rdfs:label>
    <rdfs:comment xml:lang="en">Area of the campus.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasNIRFRank">
    <rdfs:label xml:lang="en">D_hasNIRFRank</rdfs:label>
    <rdfs:comment xml:lang="en">National Institutional Ranking Framework rank.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasNAACGrade">
    <rdfs:label xml:lang="en">D_hasNAACGrade</rdfs:label>
    <rdfs:comment xml:lang="en">National Assessment and Accreditation Council grade.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_University"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasDesignation">
    <rdfs:label xml:lang="en">D_hasDesignation</rdfs:label>
    <rdfs:comment xml:lang="en">Job designation of the faculty.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Faculty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasSpecialization">
    <rdfs:label xml:lang="en">D_hasSpecialization</rdfs:label>
    <rdfs:comment xml:lang="en">Research or teaching specialization areas.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Faculty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasPhdFrom">
    <rdfs:label xml:lang="en">D_hasPhdFrom</rdfs:label>
    <rdfs:comment xml:lang="en">Institution where PhD was awarded.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Faculty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasGoogleScholarID">
    <rdfs:label xml:lang="en">D_hasGoogleScholarID</rdfs:label>
    <rdfs:comment xml:lang="en">Google Scholar profile identifier.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Faculty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasProgramLevel">
    <rdfs:label xml:lang="en">D_hasProgramLevel</rdfs:label>
    <rdfs:comment xml:lang="en">Academic level: UG, PG, or Doctoral.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Program"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasDuration">
    <rdfs:label xml:lang="en">D_hasDuration</rdfs:label>
    <rdfs:comment xml:lang="en">Duration of the program.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Program"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasTotalCredits">
    <rdfs:label xml:lang="en">D_hasTotalCredits</rdfs:label>
    <rdfs:comment xml:lang="en">Total credits required to graduate.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Program"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasTotalSeats">
    <rdfs:label xml:lang="en">D_hasTotalSeats</rdfs:label>
    <rdfs:comment xml:lang="en">Number of seats available each year.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Program"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasJEECutoff">
    <rdfs:label xml:lang="en">D_hasJEECutoff</rdfs:label>
    <rdfs:comment xml:lang="en">JEE Advanced closing rank for admission.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_UGProgram"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasGATECutoff">
    <rdfs:label xml:lang="en">D_hasGATECutoff</rdfs:label>
    <rdfs:comment xml:lang="en">GATE score required for PG admission.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_PGProgram"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasCourseCode">
    <rdfs:label xml:lang="en">D_hasCourseCode</rdfs:label>
    <rdfs:comment xml:lang="en">Official course code.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Course"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasCourseCredits">
    <rdfs:label xml:lang="en">D_hasCourseCredits</rdfs:label>
    <rdfs:comment xml:lang="en">Number of credits for the course.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Course"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasSemester">
    <rdfs:label xml:lang="en">D_hasSemester</rdfs:label>
    <rdfs:comment xml:lang="en">Semester in which the course is offered.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Course"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasCourseLevel">
    <rdfs:label xml:lang="en">D_hasCourseLevel</rdfs:label>
    <rdfs:comment xml:lang="en">Whether the course is undergraduate or postgraduate.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Course"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasResearchFocus">
    <rdfs:label xml:lang="en">D_hasResearchFocus</rdfs:label>
    <rdfs:comment xml:lang="en">Main research focus of the lab or department.</rdfs:comment>
    <rdfs:domain>
      <owl:Class><owl:unionOf rdf:parseType="Collection"><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_ResearchLab"/><rdf:Description rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_Department"/></owl:unionOf></owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasResearchAreas">
    <rdfs:label xml:lang="en">D_hasResearchAreas</rdfs:label>
    <rdfs:comment xml:lang="en">Research areas of the department.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Department"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasPublicationTitle">
    <rdfs:label xml:lang="en">D_hasPublicationTitle</rdfs:label>
    <rdfs:comment xml:lang="en">Title of the research publication.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Publication"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_hasVenue">
    <rdfs:label xml:lang="en">D_hasVenue</rdfs:label>
    <rdfs:comment xml:lang="en">Conference or journal where published.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.iiitd.ac.in/ontology/IIITD#D_Publication"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
