<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/mowl#"
     xml:base="http://example.org/mowl"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

<owl:Ontology rdf:about="http://example.org/mowl"/>

<!-- ========================= -->
<!-- CLASSES -->
<!-- ========================= -->

<owl:Class rdf:about="#Institution"/>
<owl:Class rdf:about="#Department"/>
<owl:Class rdf:about="#Program"/>
<owl:Class rdf:about="#Faculty"/>
<owl:Class rdf:about="#ResearchCenter"/>

<!-- ========================= -->
<!-- OBJECT PROPERTIES -->
<!-- ========================= -->

<owl:ObjectProperty rdf:about="#hasDepartment">
    <rdfs:domain rdf:resource="#Institution"/>
    <rdfs:range rdf:resource="#Department"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#offersProgram">
    <rdfs:domain rdf:resource="#Department"/>
    <rdfs:range rdf:resource="#Program"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasFaculty">
    <rdfs:domain rdf:resource="#Department"/>
    <rdfs:range rdf:resource="#Faculty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#belongsToDepartment">
    <rdfs:domain rdf:resource="#Faculty"/>
    <rdfs:range rdf:resource="#Department"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#worksAtInstitution">
    <rdfs:domain rdf:resource="#Faculty"/>
    <rdfs:range rdf:resource="#Institution"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasResearchCenter">
    <rdfs:domain rdf:resource="#Institution"/>
    <rdfs:range rdf:resource="#ResearchCenter"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#conductsResearch">
    <rdfs:domain rdf:resource="#Department"/>
    <rdfs:range rdf:resource="#ResearchCenter"/>
</owl:ObjectProperty>

<!-- ========================= -->
<!-- DATA PROPERTIES -->
<!-- ========================= -->

<!-- Institution Properties -->

<owl:DatatypeProperty rdf:about="#institutionName">
    <rdfs:domain rdf:resource="#Institution"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#location">
    <rdfs:domain rdf:resource="#Institution"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#website">
    <rdfs:domain rdf:resource="#Institution"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#establishedYear">
    <rdfs:domain rdf:resource="#Institution"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#institutionType">
    <rdfs:domain rdf:resource="#Institution"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#contactEmail">
    <rdfs:domain rdf:resource="#Institution"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#ranking">
    <rdfs:domain rdf:resource="#Institution"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<!-- Department Properties -->

<owl:DatatypeProperty rdf:about="#deptName">
    <rdfs:domain rdf:resource="#Department"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#deptCode">
    <rdfs:domain rdf:resource="#Department"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#departmentFocus">
    <rdfs:domain rdf:resource="#Department"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<!-- Program Properties -->

<owl:DatatypeProperty rdf:about="#programName">
    <rdfs:domain rdf:resource="#Program"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#degreeType">
    <rdfs:domain rdf:resource="#Program"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#programDuration">
    <rdfs:domain rdf:resource="#Program"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#admissionCriteria">
    <rdfs:domain rdf:resource="#Program"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#modeOfStudy">
    <rdfs:domain rdf:resource="#Program"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<!-- Faculty Properties -->

<owl:DatatypeProperty rdf:about="#facultyName">
    <rdfs:domain rdf:resource="#Faculty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#designation">
    <rdfs:domain rdf:resource="#Faculty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#facultyEmail">
    <rdfs:domain rdf:resource="#Faculty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#researchArea">
    <rdfs:domain rdf:resource="#Faculty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#officeLocation">
    <rdfs:domain rdf:resource="#Faculty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<!-- Research Center Properties -->

<owl:DatatypeProperty rdf:about="#researchFocus">
    <rdfs:domain rdf:resource="#ResearchCenter"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#fundingAgency">
    <rdfs:domain rdf:resource="#ResearchCenter"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<!-- ========================= -->
<!-- INDIVIDUALS -->
<!-- ========================= -->

<Institution rdf:about="#IIITB">
    <institutionName>IIIT Bangalore</institutionName>
    <location>Bangalore, India</location>
    <website rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in</website>
    <establishedYear rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1999</establishedYear>
</Institution>

<Institution rdf:about="#IIITH">
    <institutionName>IIIT Hyderabad</institutionName>
    <location>Hyderabad, India</location>
    <website rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiit.ac.in</website>
</Institution>

<Institution rdf:about="#IIITD">
    <institutionName>IIIT Delhi</institutionName>
    <location>New Delhi, India</location>
    <website rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitd.ac.in</website>
</Institution>

<Department rdf:about="#CSE_Department">
    <deptName>Computer Science</deptName>
    <deptCode>CSE</deptCode>
</Department>

<Department rdf:about="#DataScience_Department">
    <deptName>Data Science</deptName>
</Department>

<Program rdf:about="#BTech_CSE">
    <programName>B.Tech Computer Science</programName>
    <degreeType>BTech</degreeType>
    <programDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</programDuration>
</Program>

<Program rdf:about="#MTech_AI">
    <programName>M.Tech Artificial Intelligence</programName>
    <degreeType>MTech</degreeType>
</Program>

<Faculty rdf:about="#Prof_Raj">
    <facultyName>Prof Raj Sharma</facultyName>
    <designation>Professor</designation>
    <researchArea>Artificial Intelligence</researchArea>
</Faculty>

<Faculty rdf:about="#Prof_Anita">
    <facultyName>Prof Anita Mehta</facultyName>
    <designation>Associate Professor</designation>
</Faculty>

</rdf:RDF>
