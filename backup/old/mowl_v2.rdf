  <!-- ═══════════════════════════════════════════════════════
       DATATYPE PROPERTIES — ADMISSION
       ═══════════════════════════════════════════════════════ -->

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#admissionProcess">
