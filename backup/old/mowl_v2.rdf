    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>admissionProcess</rdfs:label>
    <rdfs:comment>JEE Advanced, GATE, IIIT entrance test, JAC Delhi, etc.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#admissionYear">
    <rdfs:domain rdf:resource="http://example.org/mowl#Admission"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>admissionYear</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#applicationDeadline">
    <rdfs:domain rdf:resource="http://example.org/mowl#Admission"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>applicationDeadline</rdfs:label>
  </owl:DatatypeProperty>


  <!-- ═══════════════════════════════════════════════════════
