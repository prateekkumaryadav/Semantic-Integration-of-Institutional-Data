    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:label>rankingYear</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#rankValue">
