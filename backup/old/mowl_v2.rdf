  <owl:DatatypeProperty rdf:about="http://example.org/mowl#rankCategory">
    <rdfs:domain rdf:resource="http://example.org/mowl#Ranking"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>rankCategory</rdfs:label>
    <rdfs:comment>e.g. Engineering, Overall, Management.</rdfs:comment>
