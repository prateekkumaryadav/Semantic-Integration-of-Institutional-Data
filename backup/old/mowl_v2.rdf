<?xml version="1.0" encoding="UTF-8"?>
<!--
  ╔══════════════════════════════════════════════════════════════════════╗
  ║  MASTER OWL v2  —  Institutional Knowledge Graph Schema             ║
  ║  URI:    http://example.org/mowl                                     ║
  ║  Covers: IIITB (b), IIITH (h), IIITD (d)  and any future source    ║
  ║  NOTE:   Schema only — no individuals.                               ║
  ║          Source ontologies map their prefixed properties to these.   ║
  ╚══════════════════════════════════════════════════════════════════════╝
-->
<rdf:RDF
    xmlns:rdf  ="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs ="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl  ="http://www.w3.org/2002/07/owl#"
    xmlns:xsd  ="http://www.w3.org/2001/XMLSchema#"
    xml:base   ="http://example.org/mowl">

  <owl:Ontology rdf:about="http://example.org/mowl">
    <rdfs:label>Master OWL v2 — Institutional Knowledge Graph</rdfs:label>
    <rdfs:comment>
      Unified schema for integrating heterogeneous institutional data from
      IIIT Bangalore (prefix b), IIIT Hyderabad (prefix h), and IIIT Delhi
      (prefix d). All source ontologies align their prefixed properties to
      the canonical properties declared here.
    </rdfs:comment>
    <owl:versionInfo>2.0</owl:versionInfo>
  </owl:Ontology>


  <!-- ═══════════════════════════════════════════════════════
       CLASSES
       ═══════════════════════════════════════════════════════ -->

  <!-- Core entity: the institution itself -->
  <owl:Class rdf:about="http://example.org/mowl#Institution">
    <rdfs:label>Institution</rdfs:label>
    <rdfs:comment>A higher-education institution (university / deemed university / institute of national importance).</rdfs:comment>
  </owl:Class>

  <!-- Academic structure -->
  <owl:Class rdf:about="http://example.org/mowl#Department">
    <rdfs:label>Department</rdfs:label>
    <rdfs:comment>An academic or research department within an institution.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/mowl#Program">
    <rdfs:label>Program</rdfs:label>
    <rdfs:comment>A degree programme offered by the institution (B.Tech, M.Tech, Ph.D, PG Diploma, Dual Degree, etc.).</rdfs:comment>
  </owl:Class>

  <!-- Subject-level course (individual subject/module within a program) -->
  <owl:Class rdf:about="http://example.org/mowl#Course">
    <rdfs:label>Course</rdfs:label>
    <rdfs:comment>An individual subject or module taught within a program (e.g. CS2.101 Discrete Mathematics).</rdfs:comment>
  </owl:Class>

  <!-- People -->
  <owl:Class rdf:about="http://example.org/mowl#Faculty">
    <rdfs:label>Faculty</rdfs:label>
    <rdfs:comment>An academic staff member or researcher at the institution.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/mowl#Student">
    <rdfs:label>Student</rdfs:label>
    <rdfs:comment>A student enrolled in a program at the institution.</rdfs:comment>
  </owl:Class>

  <!-- Research infrastructure -->
  <owl:Class rdf:about="http://example.org/mowl#ResearchCentre">
    <rdfs:label>ResearchCentre</rdfs:label>
    <rdfs:comment>A dedicated research lab or centre within the institution (e.g. CVIT, CSTAR at IIITH).</rdfs:comment>
  </owl:Class>

  <!-- Campus infrastructure -->
  <owl:Class rdf:about="http://example.org/mowl#Facility">
    <rdfs:label>Facility</rdfs:label>
    <rdfs:comment>A campus facility available to students and staff (hostel, health centre, library, incubator, etc.).</rdfs:comment>
  </owl:Class>

  <!-- Industry / placement -->
  <owl:Class rdf:about="http://example.org/mowl#Company">
    <rdfs:label>Company</rdfs:label>
    <rdfs:comment>A company that recruits from the institution during placements.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://example.org/mowl#Placement">
    <rdfs:label>Placement</rdfs:label>
    <rdfs:comment>Campus placement/recruitment statistics for a given year or batch.</rdfs:comment>
  </owl:Class>

  <!-- Rankings and accreditation -->
  <owl:Class rdf:about="http://example.org/mowl#Ranking">
    <rdfs:label>Ranking</rdfs:label>
    <rdfs:comment>A national or international ranking entry for the institution (NIRF, QS, etc.).</rdfs:comment>
  </owl:Class>

  <!-- Admissions -->
  <owl:Class rdf:about="http://example.org/mowl#Admission">
    <rdfs:label>Admission</rdfs:label>
    <rdfs:comment>Details about an admission process, cycle, or batch intake.</rdfs:comment>
  </owl:Class>

  <!-- Events -->
  <owl:Class rdf:about="http://example.org/mowl#Event">
    <rdfs:label>Event</rdfs:label>
    <rdfs:comment>An academic, cultural, or technical event hosted at the institution.</rdfs:comment>
  </owl:Class>


  <!-- ═══════════════════════════════════════════════════════
       OBJECT PROPERTIES
       ═══════════════════════════════════════════════════════ -->

  <!-- Institution level -->
  <owl:ObjectProperty rdf:about="http://example.org/mowl#hasDepartment">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Department"/>
    <rdfs:label>hasDepartment</rdfs:label>
    <rdfs:comment>Links institution to its departments.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/mowl#hasProgram">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Program"/>
    <rdfs:label>hasProgram</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/mowl#hasFaculty">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Faculty"/>
    <rdfs:label>hasFaculty</rdfs:label>
    <owl:inverseOf rdf:resource="http://example.org/mowl#worksAt"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/mowl#hasStudent">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Student"/>
    <rdfs:label>hasStudent</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/mowl#hasResearchCentre">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#ResearchCentre"/>
    <rdfs:label>hasResearchCentre</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/mowl#hasFacility">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Facility"/>
    <rdfs:label>hasFacility</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/mowl#hasPlacement">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Placement"/>
    <rdfs:label>hasPlacement</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/mowl#hasRanking">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Ranking"/>
    <rdfs:label>hasRanking</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/mowl#hasAdmission">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Admission"/>
    <rdfs:label>hasAdmission</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/mowl#hasEvent">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Event"/>
    <rdfs:label>hasEvent</rdfs:label>
  </owl:ObjectProperty>

  <!-- Department level -->
  <owl:ObjectProperty rdf:about="http://example.org/mowl#offersProgram">
    <rdfs:domain rdf:resource="http://example.org/mowl#Department"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Program"/>
    <rdfs:label>offersProgram</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/mowl#conductsCourse">
    <rdfs:domain rdf:resource="http://example.org/mowl#Department"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Course"/>
    <rdfs:label>conductsCourse</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/mowl#headedBy">
    <rdfs:domain rdf:resource="http://example.org/mowl#Department"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Faculty"/>
    <rdfs:label>headedBy</rdfs:label>
  </owl:ObjectProperty>

  <!-- Faculty level -->
  <owl:ObjectProperty rdf:about="http://example.org/mowl#belongsToDepartment">
    <rdfs:domain rdf:resource="http://example.org/mowl#Faculty"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Department"/>
    <rdfs:label>belongsToDepartment</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/mowl#worksAt">
    <rdfs:domain rdf:resource="http://example.org/mowl#Faculty"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:label>worksAt</rdfs:label>
    <owl:inverseOf rdf:resource="http://example.org/mowl#hasFaculty"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/mowl#directs">
    <rdfs:domain rdf:resource="http://example.org/mowl#Faculty"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#ResearchCentre"/>
    <rdfs:label>directs</rdfs:label>
    <owl:inverseOf rdf:resource="http://example.org/mowl#directedBy"/>
  </owl:ObjectProperty>

  <!-- ResearchCentre level -->
  <owl:ObjectProperty rdf:about="http://example.org/mowl#directedBy">
    <rdfs:domain rdf:resource="http://example.org/mowl#ResearchCentre"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Faculty"/>
    <rdfs:label>directedBy</rdfs:label>
  </owl:ObjectProperty>

  <!-- Program level -->
  <owl:ObjectProperty rdf:about="http://example.org/mowl#offeredByDepartment">
    <rdfs:domain rdf:resource="http://example.org/mowl#Program"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Department"/>
    <rdfs:label>offeredByDepartment</rdfs:label>
  </owl:ObjectProperty>

  <!-- Course level -->
  <owl:ObjectProperty rdf:about="http://example.org/mowl#taughtInDepartment">
    <rdfs:domain rdf:resource="http://example.org/mowl#Course"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Department"/>
    <rdfs:label>taughtInDepartment</rdfs:label>
  </owl:ObjectProperty>

  <!-- Student level -->
  <owl:ObjectProperty rdf:about="http://example.org/mowl#enrolledInProgram">
    <rdfs:domain rdf:resource="http://example.org/mowl#Student"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Program"/>
    <rdfs:label>enrolledInProgram</rdfs:label>
  </owl:ObjectProperty>

  <!-- Company level -->
  <owl:ObjectProperty rdf:about="http://example.org/mowl#recruitsFrom">
    <rdfs:domain rdf:resource="http://example.org/mowl#Company"/>
    <rdfs:range  rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:label>recruitsFrom</rdfs:label>
  </owl:ObjectProperty>


  <!-- ═══════════════════════════════════════════════════════
       DATATYPE PROPERTIES — INSTITUTION
       ═══════════════════════════════════════════════════════ -->

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#institutionName">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>institutionName</rdfs:label>
    <rdfs:comment>Full official name of the institution.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#institutionAbbreviation">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>institutionAbbreviation</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#institutionType">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>institutionType</rdfs:label>
    <rdfs:comment>e.g. Deemed University, Institute of National Importance, Autonomous.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#location">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>location</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#pincode">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>pincode</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#website">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    <rdfs:label>website</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#contactEmail">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>contactEmail</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#phone">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>phone</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#establishedYear">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:label>establishedYear</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#campusArea">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>campusArea</rdfs:label>
    <rdfs:comment>Area of campus in acres or hectares.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#motto">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>motto</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#affiliation">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>affiliation</rdfs:label>
    <rdfs:comment>Affiliated body or autonomous status.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#accreditation">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>accreditation</rdfs:label>
    <rdfs:comment>e.g. NAAC A, NAAC A+</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#totalStudents">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:label>totalStudents</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#totalFaculty">
    <rdfs:domain rdf:resource="http://example.org/mowl#Institution"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:label>totalFaculty</rdfs:label>
  </owl:DatatypeProperty>


  <!-- ═══════════════════════════════════════════════════════
       DATATYPE PROPERTIES — DEPARTMENT
       ═══════════════════════════════════════════════════════ -->

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#departmentName">
    <rdfs:domain rdf:resource="http://example.org/mowl#Department"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>departmentName</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#departmentAbbreviation">
    <rdfs:domain rdf:resource="http://example.org/mowl#Department"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>departmentAbbreviation</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#departmentDescription">
    <rdfs:domain rdf:resource="http://example.org/mowl#Department"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>departmentDescription</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#departmentURL">
    <rdfs:domain rdf:resource="http://example.org/mowl#Department"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    <rdfs:label>departmentURL</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#researchFocus">
    <rdfs:domain rdf:resource="http://example.org/mowl#Department"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>researchFocus</rdfs:label>
  </owl:DatatypeProperty>


  <!-- ═══════════════════════════════════════════════════════
       DATATYPE PROPERTIES — PROGRAM
       ═══════════════════════════════════════════════════════ -->

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#programName">
    <rdfs:domain rdf:resource="http://example.org/mowl#Program"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>programName</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#programType">
    <rdfs:domain rdf:resource="http://example.org/mowl#Program"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>programType</rdfs:label>
    <rdfs:comment>B.Tech, M.Tech, Ph.D, PG Diploma, Dual Degree, Integrated, etc.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#programLevel">
    <rdfs:domain rdf:resource="http://example.org/mowl#Program"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>programLevel</rdfs:label>
    <rdfs:comment>Undergraduate, Postgraduate, Doctoral, PG Diploma.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#programDuration">
    <rdfs:domain rdf:resource="http://example.org/mowl#Program"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>programDuration</rdfs:label>
    <rdfs:comment>Duration as a string e.g. "2 Years", "4 years".</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#admissionCriteria">
    <rdfs:domain rdf:resource="http://example.org/mowl#Program"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>admissionCriteria</rdfs:label>
    <rdfs:comment>JEE Advanced, GATE, IIIT entrance, direct, etc.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#totalSeats">
    <rdfs:domain rdf:resource="http://example.org/mowl#Program"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:label>totalSeats</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#modeOfStudy">
    <rdfs:domain rdf:resource="http://example.org/mowl#Program"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>modeOfStudy</rdfs:label>
    <rdfs:comment>Full-time, Part-time, Online.</rdfs:comment>
  </owl:DatatypeProperty>


  <!-- ═══════════════════════════════════════════════════════
       DATATYPE PROPERTIES — COURSE
       ═══════════════════════════════════════════════════════ -->

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#courseCode">
    <rdfs:domain rdf:resource="http://example.org/mowl#Course"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>courseCode</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#courseName">
    <rdfs:domain rdf:resource="http://example.org/mowl#Course"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>courseName</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#credits">
    <rdfs:domain rdf:resource="http://example.org/mowl#Course"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:label>credits</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#courseLevel">
    <rdfs:domain rdf:resource="http://example.org/mowl#Course"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>courseLevel</rdfs:label>
    <rdfs:comment>Undergraduate or Postgraduate.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#courseType">
    <rdfs:domain rdf:resource="http://example.org/mowl#Course"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>courseType</rdfs:label>
    <rdfs:comment>Core, Elective, Lab, Project.</rdfs:comment>
  </owl:DatatypeProperty>


  <!-- ═══════════════════════════════════════════════════════
       DATATYPE PROPERTIES — FACULTY
       ═══════════════════════════════════════════════════════ -->

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#facultyName">
    <rdfs:domain rdf:resource="http://example.org/mowl#Faculty"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>facultyName</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#designation">
    <rdfs:domain rdf:resource="http://example.org/mowl#Faculty"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>designation</rdfs:label>
    <rdfs:comment>Professor, Associate Professor, Assistant Professor, Director, etc.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#email">
    <rdfs:domain rdf:resource="http://example.org/mowl#Faculty"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>email</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#researchAreas">
    <rdfs:domain rdf:resource="http://example.org/mowl#Faculty"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>researchAreas</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#qualification">
    <rdfs:domain rdf:resource="http://example.org/mowl#Faculty"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>qualification</rdfs:label>
    <rdfs:comment>Highest degree and institution e.g. Ph.D. IIT Bombay.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#officeLocation">
    <rdfs:domain rdf:resource="http://example.org/mowl#Faculty"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>officeLocation</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#publicationsCount">
    <rdfs:domain rdf:resource="http://example.org/mowl#Faculty"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:label>publicationsCount</rdfs:label>
  </owl:DatatypeProperty>


  <!-- ═══════════════════════════════════════════════════════
