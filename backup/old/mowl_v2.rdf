  <owl:DatatypeProperty rdf:about="http://example.org/mowl#eventType">
    <rdfs:domain rdf:resource="http://example.org/mowl#Event"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>eventType</rdfs:label>
    <rdfs:comment>Technical, Cultural, Sports, Academic, etc.</rdfs:comment>
