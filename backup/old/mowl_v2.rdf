    <rdfs:label>overseasOffers</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#placementPercentage">
    <rdfs:domain rdf:resource="http://example.org/mowl#Placement"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:label>placementPercentage</rdfs:label>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/mowl#btechAveragePackage">
    <rdfs:domain rdf:resource="http://example.org/mowl#Placement"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
