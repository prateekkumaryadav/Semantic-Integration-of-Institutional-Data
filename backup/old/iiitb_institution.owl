<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE rdf:RDF [
    <!ENTITY xsd  "http://www.w3.org/2001/XMLSchema#" >
    <!ENTITY owl  "http://www.w3.org/2002/07/owl#" >
    <!ENTITY rdf  "http://www.w3.org/1999/02/22-rdf-syntax-ns#" >
    <!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#" >
    <!ENTITY mowl "http://example.org/mowl#" >
    <!ENTITY iiitb "http://example.org/iiitb#" >
]>

<!--
  ╔══════════════════════════════════════════════════════════════╗
  ║  IIIT BANGALORE — SOURCE ONTOLOGY (OWL/XML Format)          ║
  ║  Open in Protege: File → Open → this file                   ║
  ║  Namespace prefix:  iiitb:  <http://example.org/iiitb#>     ║
  ║  Master OWL prefix: mowl:   <http://example.org/mowl#>      ║
  ╚══════════════════════════════════════════════════════════════╝
-->

<rdf:RDF
    xmlns:rdf  ="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs ="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl  ="http://www.w3.org/2002/07/owl#"
    xmlns:xsd  ="http://www.w3.org/2001/XMLSchema#"
    xmlns:mowl ="http://example.org/mowl#"
    xmlns:iiitb="http://example.org/iiitb#"
    xml:base   ="http://example.org/iiitb">

    <!-- ═══════════════════════════════════════════════════
         ONTOLOGY DECLARATION
         ═══════════════════════════════════════════════════ -->
    <owl:Ontology rdf:about="http://example.org/iiitb">
        <rdfs:label>IIIT Bangalore Source Ontology</rdfs:label>
        <rdfs:comment>
            Source ontology for IIIT Bangalore institutional data.
            All classes and properties use the Master OWL (mowl) namespace
            so this file merges cleanly into the integrated knowledge graph.
        </rdfs:comment>
        <owl:versionInfo>1.0</owl:versionInfo>
    </owl:Ontology>

    <!-- ═══════════════════════════════════════════════════
         CLASS DECLARATIONS
         (Defined in mowl namespace — shared across all source ontologies)
         ═══════════════════════════════════════════════════ -->

    <owl:Class rdf:about="http://example.org/mowl#University">
        <rdfs:label xml:lang="en">University</rdfs:label>
        <rdfs:comment xml:lang="en">An institution of higher education.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/mowl#Course">
        <rdfs:label xml:lang="en">Course</rdfs:label>
        <rdfs:comment xml:lang="en">An academic program or degree offered by a university.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/mowl#Department">
        <rdfs:label xml:lang="en">Department</rdfs:label>
        <rdfs:comment xml:lang="en">A research center or academic department within a university.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/mowl#Faculty">
        <rdfs:label xml:lang="en">Faculty</rdfs:label>
        <rdfs:comment xml:lang="en">An academic staff member or professor at a university.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/mowl#Placement">
        <rdfs:label xml:lang="en">Placement</rdfs:label>
        <rdfs:comment xml:lang="en">Campus recruitment / placement statistics for a student batch.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/mowl#Ranking">
        <rdfs:label xml:lang="en">Ranking</rdfs:label>
        <rdfs:comment xml:lang="en">A national or international ranking entry for an institution.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/mowl#Recruiter">
        <rdfs:label xml:lang="en">Recruiter</rdfs:label>
        <rdfs:comment xml:lang="en">A company that hires students from the institution.</rdfs:comment>
    </owl:Class>

    <!-- ═══════════════════════════════════════════════════
         OBJECT PROPERTY DECLARATIONS
         ═══════════════════════════════════════════════════ -->

    <owl:ObjectProperty rdf:about="http://example.org/mowl#hasCourse">
        <rdfs:label xml:lang="en">hasCourse</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/mowl#University"/>
        <rdfs:range  rdf:resource="http://example.org/mowl#Course"/>
        <owl:inverseOf rdf:resource="http://example.org/mowl#offeredBy"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/mowl#offeredBy">
        <rdfs:label xml:lang="en">offeredBy</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/mowl#Course"/>
        <rdfs:range  rdf:resource="http://example.org/mowl#University"/>
        <owl:inverseOf rdf:resource="http://example.org/mowl#hasCourse"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/mowl#hasDepartment">
        <rdfs:label xml:lang="en">hasDepartment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/mowl#University"/>
        <rdfs:range  rdf:resource="http://example.org/mowl#Department"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/mowl#hasFaculty">
        <rdfs:label xml:lang="en">hasFaculty</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/mowl#University"/>
        <rdfs:range  rdf:resource="http://example.org/mowl#Faculty"/>
        <owl:inverseOf rdf:resource="http://example.org/mowl#worksAt"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/mowl#worksAt">
        <rdfs:label xml:lang="en">worksAt</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/mowl#Faculty"/>
        <rdfs:range  rdf:resource="http://example.org/mowl#University"/>
        <owl:inverseOf rdf:resource="http://example.org/mowl#hasFaculty"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/mowl#hasPlacement">
        <rdfs:label xml:lang="en">hasPlacement</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/mowl#University"/>
        <rdfs:range  rdf:resource="http://example.org/mowl#Placement"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/mowl#hasRanking">
        <rdfs:label xml:lang="en">hasRanking</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/mowl#University"/>
        <rdfs:range  rdf:resource="http://example.org/mowl#Ranking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/mowl#hires">
        <rdfs:label xml:lang="en">hires</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/mowl#Recruiter"/>
        <rdfs:range  rdf:resource="http://example.org/mowl#University"/>
    </owl:ObjectProperty>

    <!-- ═══════════════════════════════════════════════════
         DATATYPE PROPERTY DECLARATIONS
         ═══════════════════════════════════════════════════ -->

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#hasName">
        <rdfs:label xml:lang="en">hasName</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#hasFullName">
        <rdfs:label xml:lang="en">hasFullName</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#hasWebsite">
        <rdfs:label xml:lang="en">hasWebsite</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#locatedIn">
        <rdfs:label xml:lang="en">locatedIn</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#establishedYear">
        <rdfs:label xml:lang="en">establishedYear</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#institutionType">
        <rdfs:label xml:lang="en">institutionType</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#nirfRank">
        <rdfs:label xml:lang="en">nirfRank</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#accreditation">
        <rdfs:label xml:lang="en">accreditation</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#averageSalary">
        <rdfs:label xml:lang="en">averageSalary (LPA)</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#highestSalary">
        <rdfs:label xml:lang="en">highestSalary (LPA)</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#medianSalary">
        <rdfs:label xml:lang="en">medianSalary (LPA)</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#placementPercentage">
        <rdfs:label xml:lang="en">placementPercentage</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#totalPlaced">
        <rdfs:label xml:lang="en">totalPlaced</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#degreeType">
        <rdfs:label xml:lang="en">degreeType</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#degreeName">
        <rdfs:label xml:lang="en">degreeName</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#duration">
        <rdfs:label xml:lang="en">duration</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#researchArea">
        <rdfs:label xml:lang="en">researchArea</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/mowl#designation">
        <rdfs:label xml:lang="en">designation</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- ═══════════════════════════════════════════════════
         INDIVIDUAL — UNIVERSITY
         ═══════════════════════════════════════════════════ -->

    <owl:NamedIndividual rdf:about="http://example.org/iiitb#IIITB">
        <rdf:type rdf:resource="http://example.org/mowl#University"/>
        <rdfs:label xml:lang="en">IIIT Bangalore</rdfs:label>
        <rdfs:comment xml:lang="en">International Institute of Information Technology Bangalore — premier deemed university focused on IT and research.</rdfs:comment>
        <mowl:hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IIIT Bangalore</mowl:hasName>
        <mowl:hasFullName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">International Institute of Information Technology Bangalore</mowl:hasFullName>
        <mowl:hasWebsite rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in</mowl:hasWebsite>
        <mowl:locatedIn rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bangalore</mowl:locatedIn>
        <mowl:institutionType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Deemed University</mowl:institutionType>
        <mowl:establishedYear rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1999</mowl:establishedYear>
        <!-- Courses -->
        <mowl:hasCourse rdf:resource="http://example.org/iiitb#Course_1_MTech_CSE"/>
        <mowl:hasCourse rdf:resource="http://example.org/iiitb#Course_2_MTech_ECE"/>
        <mowl:hasCourse rdf:resource="http://example.org/iiitb#Course_3_MTech_IT"/>
        <mowl:hasCourse rdf:resource="http://example.org/iiitb#Course_4_MTech_DataScience"/>
        <mowl:hasCourse rdf:resource="http://example.org/iiitb#Course_5_MTech_CompLing"/>
        <mowl:hasCourse rdf:resource="http://example.org/iiitb#Course_6_MTech_VLSI"/>
        <mowl:hasCourse rdf:resource="http://example.org/iiitb#Course_7_MTech_DigitalSociety"/>
        <mowl:hasCourse rdf:resource="http://example.org/iiitb#Course_8_PhD_CS"/>
        <mowl:hasCourse rdf:resource="http://example.org/iiitb#Course_9_PhD_ECE"/>
        <mowl:hasCourse rdf:resource="http://example.org/iiitb#Course_10_iMTech_CSE"/>
        <!-- Departments -->
        <mowl:hasDepartment rdf:resource="http://example.org/iiitb#Dept_AI"/>
        <mowl:hasDepartment rdf:resource="http://example.org/iiitb#Dept_DataSciences"/>
        <mowl:hasDepartment rdf:resource="http://example.org/iiitb#Dept_VLSI"/>
        <mowl:hasDepartment rdf:resource="http://example.org/iiitb#Dept_CyberSecurity"/>
        <mowl:hasDepartment rdf:resource="http://example.org/iiitb#Dept_CompLinguistics"/>
        <mowl:hasDepartment rdf:resource="http://example.org/iiitb#Dept_HealthcareInformatics"/>
        <mowl:hasDepartment rdf:resource="http://example.org/iiitb#Dept_DigitalGovernance"/>
        <mowl:hasDepartment rdf:resource="http://example.org/iiitb#Dept_BuildingScience"/>
        <mowl:hasDepartment rdf:resource="http://example.org/iiitb#Dept_EduTechnology"/>
        <!-- Faculty -->
        <mowl:hasFaculty rdf:resource="http://example.org/iiitb#Faculty_1_DebabrataDas"/>
        <mowl:hasFaculty rdf:resource="http://example.org/iiitb#Faculty_2_GNSrinivasa"/>
        <mowl:hasFaculty rdf:resource="http://example.org/iiitb#Faculty_3_SrinathSrinivasa"/>
        <mowl:hasFaculty rdf:resource="http://example.org/iiitb#Faculty_4_ChandrashekharR"/>
        <mowl:hasFaculty rdf:resource="http://example.org/iiitb#Faculty_5_JyothiVedurada"/>
        <mowl:hasFaculty rdf:resource="http://example.org/iiitb#Faculty_6_DineshBabu"/>
        <mowl:hasFaculty rdf:resource="http://example.org/iiitb#Faculty_7_NeelaSinha"/>
        <mowl:hasFaculty rdf:resource="http://example.org/iiitb#Faculty_8_ShrishaRao"/>
        <!-- Placement and Ranking -->
        <mowl:hasPlacement rdf:resource="http://example.org/iiitb#Placement_2023_24"/>
        <mowl:hasRanking   rdf:resource="http://example.org/iiitb#Ranking_NIRF_2023"/>
    </owl:NamedIndividual>

    <!-- ═══════════════════════════════════════════════════
         INDIVIDUALS — COURSES
         ═══════════════════════════════════════════════════ -->

    <owl:NamedIndividual rdf:about="http://example.org/iiitb#Course_1_MTech_CSE">
        <rdf:type rdf:resource="http://example.org/mowl#Course"/>
        <rdfs:label xml:lang="en">MTech in Computer Science and Engineering</rdfs:label>
        <mowl:hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MTech in Computer Science and Engineering</mowl:hasName>
        <mowl:degreeType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MTech</mowl:degreeType>
        <mowl:degreeName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Postgraduate</mowl:degreeName>
        <mowl:duration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2 years</mowl:duration>
        <mowl:offeredBy rdf:resource="http://example.org/iiitb#IIITB"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/iiitb#Course_2_MTech_ECE">
        <rdf:type rdf:resource="http://example.org/mowl#Course"/>
        <rdfs:label xml:lang="en">MTech in Electronics and Communication Engineering</rdfs:label>
        <mowl:hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MTech in Electronics and Communication Engineering</mowl:hasName>
        <mowl:degreeType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MTech</mowl:degreeType>
        <mowl:degreeName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Postgraduate</mowl:degreeName>
        <mowl:duration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2 years</mowl:duration>
        <mowl:offeredBy rdf:resource="http://example.org/iiitb#IIITB"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/iiitb#Course_3_MTech_IT">
        <rdf:type rdf:resource="http://example.org/mowl#Course"/>
        <rdfs:label xml:lang="en">MTech in Information Technology</rdfs:label>
        <mowl:hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MTech in Information Technology</mowl:hasName>
        <mowl:degreeType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MTech</mowl:degreeType>
        <mowl:degreeName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Postgraduate</mowl:degreeName>
        <mowl:duration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2 years</mowl:duration>
        <mowl:offeredBy rdf:resource="http://example.org/iiitb#IIITB"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/iiitb#Course_4_MTech_DataScience">
        <rdf:type rdf:resource="http://example.org/mowl#Course"/>
        <rdfs:label xml:lang="en">MTech in Data Science</rdfs:label>
        <mowl:hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MTech in Data Science</mowl:hasName>
        <mowl:degreeType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MTech</mowl:degreeType>
        <mowl:degreeName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Postgraduate</mowl:degreeName>
        <mowl:duration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2 years</mowl:duration>
        <mowl:researchArea rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Data Science, Machine Learning, Analytics</mowl:researchArea>
        <mowl:offeredBy rdf:resource="http://example.org/iiitb#IIITB"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/iiitb#Course_5_MTech_CompLing">
        <rdf:type rdf:resource="http://example.org/mowl#Course"/>
        <rdfs:label xml:lang="en">MTech in Computational Linguistics</rdfs:label>
        <mowl:hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MTech in Computational Linguistics</mowl:hasName>
        <mowl:degreeType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MTech</mowl:degreeType>
        <mowl:degreeName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Postgraduate</mowl:degreeName>
        <mowl:duration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2 years</mowl:duration>
        <mowl:researchArea rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NLP, Linguistics, Language Processing</mowl:researchArea>
        <mowl:offeredBy rdf:resource="http://example.org/iiitb#IIITB"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/iiitb#Course_6_MTech_VLSI">
        <rdf:type rdf:resource="http://example.org/mowl#Course"/>
        <rdfs:label xml:lang="en">MTech in VLSI and Embedded Systems</rdfs:label>
        <mowl:hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MTech in VLSI and Embedded Systems</mowl:hasName>
        <mowl:degreeType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MTech</mowl:degreeType>
        <mowl:degreeName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Postgraduate</mowl:degreeName>
        <mowl:duration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2 years</mowl:duration>
        <mowl:researchArea rdf:datatype="http://www.w3.org/2001/XMLSchema#string">VLSI, Chip Design, Embedded Systems</mowl:researchArea>
        <mowl:offeredBy rdf:resource="http://example.org/iiitb#IIITB"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/iiitb#Course_7_MTech_DigitalSociety">
        <rdf:type rdf:resource="http://example.org/mowl#Course"/>
        <rdfs:label xml:lang="en">MTech in Digital Society</rdfs:label>
        <mowl:hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MTech in Digital Society</mowl:hasName>
        <mowl:degreeType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MTech</mowl:degreeType>
        <mowl:degreeName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Postgraduate</mowl:degreeName>
        <mowl:duration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2 years</mowl:duration>
        <mowl:researchArea rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Digital Governance, e-Governance, Social Computing</mowl:researchArea>
        <mowl:offeredBy rdf:resource="http://example.org/iiitb#IIITB"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/iiitb#Course_8_PhD_CS">
        <rdf:type rdf:resource="http://example.org/mowl#Course"/>
        <rdfs:label xml:lang="en">PhD in Computer Science</rdfs:label>
        <mowl:hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PhD in Computer Science</mowl:hasName>
        <mowl:degreeType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PhD</mowl:degreeType>
        <mowl:degreeName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Doctoral</mowl:degreeName>
        <mowl:duration rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4-5 years</mowl:duration>
        <mowl:offeredBy rdf:resource="http://example.org/iiitb#IIITB"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/iiitb#Course_9_PhD_ECE">
        <rdf:type rdf:resource="http://example.org/mowl#Course"/>
        <rdfs:label xml:lang="en">PhD in Electronics and Communication</rdfs:label>
        <mowl:hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PhD in Electronics and Communication</mowl:hasName>
