 xmlns:ex="http://example.org/iiitb#">

<!-- Institution -->
<rdf:Description rdf:about="http://example.org/iiitb#IIITB">
 <rdf:type rdf:resource="http://example.org/iiitb#Institution"/>
 <ex:bHasInstitutionName>IIIT Bangalore</ex:bHasInstitutionName>
 <ex:bHasLocation>Bangalore</ex:bHasLocation>
</rdf:Description>

<!-- Departments -->
<rdf:Description rdf:about="http://example.org/iiitb#Computer_Science">
 <rdf:type rdf:resource="http://example.org/iiitb#Department"/>
 <ex:bHasDepartmentName>Computer Science</ex:bHasDepartmentName>
</rdf:Description>

<rdf:Description rdf:about="http://example.org/iiitb#Data_Science">
