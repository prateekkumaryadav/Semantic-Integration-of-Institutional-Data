iiitb:IIITB
    rdf:type owl:NamedIndividual, mowl:University ;
    rdfs:label                "IIIT Bangalore"@en ;
    rdfs:comment              "International Institute of Information Technology Bangalore, a premier deemed university focused on IT and research."@en ;
    mowl:hasName              "IIIT Bangalore"^^xsd:string ;
    mowl:hasFullName          "International Institute of Information Technology Bangalore"^^xsd:string ;
    mowl:hasWebsite           "https://www.iiitb.ac.in"^^xsd:anyURI ;
    mowl:locatedIn            "Bangalore"^^xsd:string ;
    mowl:institutionType      "Deemed University"^^xsd:string ;
    mowl:establishedYear      "1999"^^xsd:integer ;

    # ── Courses ──────────────────────────────────
    mowl:hasCourse            iiitb:Course_1_MTech_CSE ,
                              iiitb:Course_2_MTech_ECE ,
                              iiitb:Course_3_MTech_IT ,
                              iiitb:Course_4_MTech_DataScience ,
                              iiitb:Course_5_MTech_CompLing ,
                              iiitb:Course_6_MTech_VLSI ,
                              iiitb:Course_7_MTech_DigitalSociety ,
                              iiitb:Course_8_PhD_CS ,
                              iiitb:Course_9_PhD_ECE ,
                              iiitb:Course_10_iMTech_CSE ;

    # ── Departments ──────────────────────────────
    mowl:hasDepartment        iiitb:Dept_DataSciences ,
                              iiitb:Dept_CyberSecurity ,
                              iiitb:Dept_VLSI ,
                              iiitb:Dept_AI ,
                              iiitb:Dept_CompLinguistics ,
                              iiitb:Dept_HealthcareInformatics ,
                              iiitb:Dept_DigitalGovernance ,
                              iiitb:Dept_BuildingScience ,
                              iiitb:Dept_EduTechnology ;

    # ── Faculty ──────────────────────────────────
    mowl:hasFaculty           iiitb:Faculty_1_DebabrataDas ,
                              iiitb:Faculty_2_GNSrinivasa ,
                              iiitb:Faculty_3_SrinathSrinivasa ,
                              iiitb:Faculty_4_ChandrashekharR ,
                              iiitb:Faculty_5_JyothiVedurada ,
                              iiitb:Faculty_6_DineshBabu ,
                              iiitb:Faculty_7_NeelaSinha ,
