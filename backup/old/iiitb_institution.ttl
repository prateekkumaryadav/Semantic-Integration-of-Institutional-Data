@prefix iiitb:  <http://example.org/iiitb#> .
@prefix mowl:   <http://example.org/mowl#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <https://schema.org/> .

# ═══════════════════════════════════════════════════════════════
#  IIIT BANGALORE — SOURCE ONTOLOGY (OWL-Compatible RDF)
#  Generated by: iiitb_scraper.py
#  Source:       https://www.iiitb.ac.in/
#  Purpose:      Integration into Master OWL (mowl)
#  Format:       Turtle (.ttl)  —  load directly in Protege/Fuseki
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────
#  OWL ONTOLOGY DECLARATION
# ───────────────────────────────────────────────
<http://example.org/iiitb>
    rdf:type owl:Ontology ;
    rdfs:label "IIIT Bangalore Source Ontology"@en ;
    rdfs:comment "Source ontology for IIIT Bangalore institutional data, mapped to Master OWL namespace."@en ;
    owl:imports <http://example.org/mowl> .

# ───────────────────────────────────────────────
#  CLASS DECLARATIONS (from Master OWL — mowl)
#  Declared here so this file is self-contained
#  and loadable standalone in Protege
# ───────────────────────────────────────────────
mowl:University
    rdf:type owl:Class ;
    rdfs:label "University"@en ;
    rdfs:comment "An institution of higher education."@en .

mowl:Course
    rdf:type owl:Class ;
    rdfs:label "Course"@en ;
    rdfs:comment "An academic program or degree offered by a university."@en .

mowl:Department
    rdf:type owl:Class ;
    rdfs:label "Department"@en ;
    rdfs:comment "A research center or academic department within a university."@en .

mowl:Faculty
    rdf:type owl:Class ;
    rdfs:label "Faculty"@en ;
    rdfs:comment "An academic staff member or professor."@en .

mowl:Placement
    rdf:type owl:Class ;
    rdfs:label "Placement"@en ;
    rdfs:comment "Placement statistics for a batch of students."@en .

mowl:Ranking
    rdf:type owl:Class ;
    rdfs:label "Ranking"@en ;
    rdfs:comment "A national or international ranking for the institution."@en .

mowl:Recruiter
    rdf:type owl:Class ;
    rdfs:label "Recruiter"@en ;
    rdfs:comment "A company that hires students from the institution."@en .

# ───────────────────────────────────────────────
#  OBJECT PROPERTY DECLARATIONS
# ───────────────────────────────────────────────
mowl:hasCourse
    rdf:type owl:ObjectProperty ;
    rdfs:domain mowl:University ;
    rdfs:range  mowl:Course ;
    rdfs:label  "hasCourse"@en .

mowl:hasDepartment
    rdf:type owl:ObjectProperty ;
    rdfs:domain mowl:University ;
    rdfs:range  mowl:Department ;
    rdfs:label  "hasDepartment"@en .

mowl:hasFaculty
    rdf:type owl:ObjectProperty ;
    rdfs:domain mowl:University ;
    rdfs:range  mowl:Faculty ;
    rdfs:label  "hasFaculty"@en .

mowl:hasPlacement
    rdf:type owl:ObjectProperty ;
    rdfs:domain mowl:University ;
    rdfs:range  mowl:Placement ;
    rdfs:label  "hasPlacement"@en .

mowl:hasRanking
    rdf:type owl:ObjectProperty ;
    rdfs:domain mowl:University ;
    rdfs:range  mowl:Ranking ;
    rdfs:label  "hasRanking"@en .

mowl:offeredBy
    rdf:type owl:ObjectProperty ;
    rdfs:domain mowl:Course ;
    rdfs:range  mowl:University ;
    rdfs:label  "offeredBy"@en ;
    owl:inverseOf mowl:hasCourse .

mowl:worksAt
    rdf:type owl:ObjectProperty ;
    rdfs:domain mowl:Faculty ;
    rdfs:range  mowl:University ;
    rdfs:label  "worksAt"@en ;
    owl:inverseOf mowl:hasFaculty .

mowl:hires
    rdf:type owl:ObjectProperty ;
    rdfs:domain mowl:Recruiter ;
    rdfs:range  mowl:University ;
    rdfs:label  "hires"@en .

# ───────────────────────────────────────────────
#  DATATYPE PROPERTY DECLARATIONS
# ───────────────────────────────────────────────
mowl:hasName
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "hasName"@en .

mowl:hasFullName
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "hasFullName"@en .

mowl:hasWebsite
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:anyURI ;
    rdfs:label "hasWebsite"@en .

mowl:locatedIn
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "locatedIn"@en .

mowl:establishedYear
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "establishedYear"@en .

mowl:institutionType
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "institutionType"@en .

mowl:nirfRank
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "nirfRank"@en .

mowl:accreditation
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "accreditation"@en .

mowl:averageSalary
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:float ;
    rdfs:label "averageSalary (LPA)"@en .

mowl:highestSalary
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:float ;
    rdfs:label "highestSalary (LPA)"@en .

mowl:medianSalary
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:float ;
    rdfs:label "medianSalary (LPA)"@en .

mowl:placementPercentage
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:float ;
    rdfs:label "placementPercentage"@en .

mowl:totalPlaced
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "totalPlaced"@en .

mowl:degreeType
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "degreeType"@en .

mowl:degreeName
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "degreeName"@en .

mowl:duration
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "duration"@en .

mowl:researchArea
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "researchArea"@en .

mowl:designation
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "designation"@en .

