  <!-- CLASSES -->
  <owl:Class rdf:about="http://www.iiitd.ac.in/ontology/IIITD#D_University"><rdfs:label xml:lang="en">D_University</rdfs:label><rdfs:comment xml:lang="en">A university or academic institution.</rdfs:comment></owl:Class>
