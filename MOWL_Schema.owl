  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#participatesIn">
    <rdfs:label xml:lang="en">participatesIn</rdfs:label>
    <rdfs:comment xml:lang="en">Person participates in an event or activity</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Person"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#speakerAt">
    <rdfs:label xml:lang="en">speakerAt</rdfs:label>
    <rdfs:comment xml:lang="en">Person is a speaker at an event</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Person"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Event"/>
  </owl:ObjectProperty>

  <!-- ════════════════════════════════════════════════════════════════════════
       OBJECT PROPERTIES - Student Club & Organization Relationships
  ════════════════════════════════════════════════════════════════════════ -->

  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#hasClub">
    <rdfs:label xml:lang="en">hasClub</rdfs:label>
    <rdfs:comment xml:lang="en">Institution has a student club</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Institution"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#StudentClub"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#presidentOf">
    <rdfs:label xml:lang="en">presidentOf</rdfs:label>
    <rdfs:comment xml:lang="en">Student is president of a club</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Student"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#StudentClub"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#facultyAdvisor">
    <rdfs:label xml:lang="en">facultyAdvisor</rdfs:label>
    <rdfs:comment xml:lang="en">Faculty advisor of a club or organization</rdfs:comment>
    <rdfs:range rdf:resource="http://www.semanticweb.org/mowl#Faculty"/>
  </owl:ObjectProperty>

  <!-- ════════════════════════════════════════════════════════════════════════
       OBJECT PROPERTIES - Additional Generic Relationships
  ════════════════════════════════════════════════════════════════════════ -->

  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#relatedTo">
    <rdfs:label xml:lang="en">relatedTo</rdfs:label>
    <rdfs:comment xml:lang="en">Generic relationship between entities</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#partOf">
    <rdfs:label xml:lang="en">partOf</rdfs:label>
    <rdfs:comment xml:lang="en">Entity is part of another entity</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#hasPart">
    <rdfs:label xml:lang="en">hasPart</rdfs:label>
    <rdfs:comment xml:lang="en">Entity has a part</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/mowl#partOf"/>
  </owl:ObjectProperty>

