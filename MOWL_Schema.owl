  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/mowl#belongsToInstitution">
    <rdfs:label xml:lang="en">belongsToInstitution</rdfs:label>
    <rdfs:comment xml:lang="en">Entity belongs to an institution</rdfs:comment>
