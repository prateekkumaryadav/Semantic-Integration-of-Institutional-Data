<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
  xmlns:dc="http://purl.org/dc/elements/1.1/"
  xmlns:foaf="http://xmlns.com/foaf/0.1/"
  xmlns:mowl="http://www.semanticweb.org/mowl#"
  xml:base="http://www.semanticweb.org/mowl#">

  <!-- ════════════════════════════════════════════════════════════════════════
       MASTER OWL (MOWL) SCHEMA
       Comprehensive Ontology for Academic Institutions
       
       This master ontology integrates schemas from multiple sources (IIITH, IIITB, IIITD)
       and provides a unified, extensible framework for representing academic institutions.
       
       Version: 1.0.0
       Created: 2025
       Purpose: Universal schema for perfect and ideal Institute representation
  ════════════════════════════════════════════════════════════════════════ -->

  <owl:Ontology rdf:about="http://www.semanticweb.org/mowl#">
    <dc:title>Master OWL (MOWL) - Universal Academic Institution Ontology</dc:title>
    <dc:description>
      Comprehensive OWL ontology for academic institutions covering all aspects:
      organizational structure, academic programs, faculty, students, research,
      placements, facilities, accreditations, and industry partnerships.
      Designed to accommodate multiple source schemas while providing a unified model.
    </dc:description>
    <dc:creator>Master OWL Schema Generator</dc:creator>
    <dc:date>2025-03-09</dc:date>
    <owl:versionInfo>1.0.0</owl:versionInfo>
  </owl:Ontology>

  <!-- ════════════════════════════════════════════════════════════════════════
       CORE CLASSES - Top-level organizational entities
  ════════════════════════════════════════════════════════════════════════ -->

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Institution">
    <rdfs:label xml:lang="en">Institution</rdfs:label>
    <rdfs:comment xml:lang="en">
      An academic institution such as a university, college, or research institute.
      This is the top-level entity representing the entire organization.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Department">
    <rdfs:label xml:lang="en">Department</rdfs:label>
    <rdfs:comment xml:lang="en">
      An academic or administrative department within an institution.
      Departments offer programs, employ faculty, and conduct research.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Institution"/>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#School">
    <rdfs:label xml:lang="en">School</rdfs:label>
    <rdfs:comment xml:lang="en">
      A school or college within a larger institution, typically comprising multiple departments.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Institution"/>
  </owl:Class>

  <!-- ════════════════════════════════════════════════════════════════════════
       PEOPLE CLASSES - Faculty, Students, Staff
  ════════════════════════════════════════════════════════════════════════ -->

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Person">
    <rdfs:label xml:lang="en">Person</rdfs:label>
    <rdfs:comment xml:lang="en">
      A person associated with the institution. Base class for all human entities.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Faculty">
    <rdfs:label xml:lang="en">Faculty Member</rdfs:label>
    <rdfs:comment xml:lang="en">
      A faculty member, professor, or teaching staff at the institution.
      Includes all academic ranks: Professor, Associate Professor, Assistant Professor, Lecturer, etc.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Person"/>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Student">
    <rdfs:label xml:lang="en">Student</rdfs:label>
    <rdfs:comment xml:lang="en">
      A student enrolled in a program at the institution.
      Includes undergraduate, postgraduate, and doctoral students.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Person"/>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Staff">
    <rdfs:label xml:lang="en">Staff</rdfs:label>
    <rdfs:comment xml:lang="en">
      Administrative or support staff at the institution.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Person"/>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Alumni">
    <rdfs:label xml:lang="en">Alumni</rdfs:label>
    <rdfs:comment xml:lang="en">
      A former student who has graduated from the institution.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Person"/>
  </owl:Class>

  <!-- ════════════════════════════════════════════════════════════════════════
       ACADEMIC PROGRAM CLASSES
  ════════════════════════════════════════════════════════════════════════ -->

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Program">
    <rdfs:label xml:lang="en">Academic Program</rdfs:label>
    <rdfs:comment xml:lang="en">
      An academic program or degree program offered by the institution.
      Base class for all program types.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#UndergraduateProgram">
    <rdfs:label xml:lang="en">Undergraduate Program</rdfs:label>
    <rdfs:comment xml:lang="en">
      A bachelor's level academic program (B.Tech, B.Sc, B.A, etc.).
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Program"/>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#PostgraduateProgram">
    <rdfs:label xml:lang="en">Postgraduate Program</rdfs:label>
    <rdfs:comment xml:lang="en">
      A master's level academic program (M.Tech, M.Sc, MBA, etc.).
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Program"/>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#DoctoralProgram">
    <rdfs:label xml:lang="en">Doctoral Program</rdfs:label>
    <rdfs:comment xml:lang="en">
      A doctoral or Ph.D. level research program.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Program"/>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#DiplomaProgram">
    <rdfs:label xml:lang="en">Diploma Program</rdfs:label>
    <rdfs:comment xml:lang="en">
      A diploma or certificate program.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Program"/>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Course">
    <rdfs:label xml:lang="en">Course</rdfs:label>
    <rdfs:comment xml:lang="en">
      An individual course, subject, or module within a program.
    </rdfs:comment>
  </owl:Class>

  <!-- ════════════════════════════════════════════════════════════════════════
       RESEARCH CLASSES
  ════════════════════════════════════════════════════════════════════════ -->

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#ResearchLab">
    <rdfs:label xml:lang="en">Research Laboratory</rdfs:label>
    <rdfs:comment xml:lang="en">
      A research laboratory, group, or team conducting research in specific areas.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#ResearchCentre">
    <rdfs:label xml:lang="en">Research Centre</rdfs:label>
    <rdfs:comment xml:lang="en">
      A research center or institute focused on specific research domains.
      Larger organizational unit than a lab, may contain multiple labs.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#ResearchProject">
    <rdfs:label xml:lang="en">Research Project</rdfs:label>
    <rdfs:comment xml:lang="en">
      A funded or ongoing research project with specific objectives and timeline.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Publication">
    <rdfs:label xml:lang="en">Publication</rdfs:label>
    <rdfs:comment xml:lang="en">
      A research publication such as a journal article, conference paper, book chapter, etc.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Patent">
    <rdfs:label xml:lang="en">Patent</rdfs:label>
    <rdfs:comment xml:lang="en">
      A patent filed or granted to faculty or the institution.
    </rdfs:comment>
  </owl:Class>

  <!-- ════════════════════════════════════════════════════════════════════════
       INFRASTRUCTURE & FACILITIES CLASSES
  ════════════════════════════════════════════════════════════════════════ -->

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Facility">
    <rdfs:label xml:lang="en">Facility</rdfs:label>
    <rdfs:comment xml:lang="en">
      A physical or digital facility available at the institution.
      Base class for all facility types.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#AcademicFacility">
    <rdfs:label xml:lang="en">Academic Facility</rdfs:label>
    <rdfs:comment xml:lang="en">
      Academic facilities like libraries, labs, classrooms, lecture halls, etc.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Facility"/>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#ResidentialFacility">
    <rdfs:label xml:lang="en">Residential Facility</rdfs:label>
    <rdfs:comment xml:lang="en">
      Residential facilities like hostels, dormitories, guest houses, etc.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Facility"/>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#SportsFacility">
    <rdfs:label xml:lang="en">Sports Facility</rdfs:label>
    <rdfs:comment xml:lang="en">
      Sports and recreational facilities like grounds, gyms, courts, etc.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Facility"/>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#MedicalFacility">
    <rdfs:label xml:lang="en">Medical Facility</rdfs:label>
    <rdfs:comment xml:lang="en">
      Medical and health facilities like clinics, hospitals, wellness centers, etc.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Facility"/>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#FoodFacility">
    <rdfs:label xml:lang="en">Food Facility</rdfs:label>
    <rdfs:comment xml:lang="en">
      Food and dining facilities like cafeterias, canteens, mess halls, etc.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Facility"/>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#InnovationFacility">
    <rdfs:label xml:lang="en">Innovation Facility</rdfs:label>
    <rdfs:comment xml:lang="en">
      Innovation and entrepreneurship facilities like incubators, makerspaces, fab labs, etc.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Facility"/>
  </owl:Class>

  <!-- ════════════════════════════════════════════════════════════════════════
       CAREER & PLACEMENT CLASSES
  ════════════════════════════════════════════════════════════════════════ -->

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Placement">
    <rdfs:label xml:lang="en">Placement Record</rdfs:label>
    <rdfs:comment xml:lang="en">
      Placement statistics and records for a given academic year.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Recruiter">
    <rdfs:label xml:lang="en">Recruiter/Company</rdfs:label>
    <rdfs:comment xml:lang="en">
      A company or organization that recruits students from the institution.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#IndustryPartner">
    <rdfs:label xml:lang="en">Industry Partner</rdfs:label>
    <rdfs:comment xml:lang="en">
      An industry partner collaborating with the institution for research,
      funding, training, or recruitment.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Internship">
    <rdfs:label xml:lang="en">Internship</rdfs:label>
    <rdfs:comment xml:lang="en">
      An internship opportunity or program offered to students.
    </rdfs:comment>
  </owl:Class>

  <!-- ════════════════════════════════════════════════════════════════════════
       QUALITY & ACCREDITATION CLASSES
  ════════════════════════════════════════════════════════════════════════ -->

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Accreditation">
    <rdfs:label xml:lang="en">Accreditation</rdfs:label>
    <rdfs:comment xml:lang="en">
      An accreditation, certification, or ranking received by the institution or programs.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Ranking">
    <rdfs:label xml:lang="en">Ranking</rdfs:label>
    <rdfs:comment xml:lang="en">
      Rankings from national or international ranking bodies.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Award">
    <rdfs:label xml:lang="en">Award</rdfs:label>
    <rdfs:comment xml:lang="en">
      Awards or recognitions received by the institution, faculty, or students.
    </rdfs:comment>
  </owl:Class>

  <!-- ════════════════════════════════════════════════════════════════════════
       EVENTS & ACTIVITIES CLASSES
  ════════════════════════════════════════════════════════════════════════ -->

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Event">
    <rdfs:label xml:lang="en">Event</rdfs:label>
    <rdfs:comment xml:lang="en">
      An event, conference, workshop, seminar, or activity organized by or at the institution.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Conference">
    <rdfs:label xml:lang="en">Conference</rdfs:label>
    <rdfs:comment xml:lang="en">
      An academic or professional conference.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Event"/>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Workshop">
    <rdfs:label xml:lang="en">Workshop</rdfs:label>
    <rdfs:comment xml:lang="en">
      A workshop or hands-on training session.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Event"/>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#Seminar">
    <rdfs:label xml:lang="en">Seminar</rdfs:label>
    <rdfs:comment xml:lang="en">
      A seminar or guest lecture.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#Event"/>
  </owl:Class>

  <!-- ════════════════════════════════════════════════════════════════════════
       STUDENT ORGANIZATIONS & CLUBS
  ════════════════════════════════════════════════════════════════════════ -->

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#StudentClub">
    <rdfs:label xml:lang="en">Student Club</rdfs:label>
    <rdfs:comment xml:lang="en">
      A student club, society, or organization.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#TechnicalClub">
    <rdfs:label xml:lang="en">Technical Club</rdfs:label>
    <rdfs:comment xml:lang="en">
      A technical or academic club focused on specific domains.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#StudentClub"/>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/mowl#CulturalClub">
    <rdfs:label xml:lang="en">Cultural Club</rdfs:label>
    <rdfs:comment xml:lang="en">
      A cultural, arts, or entertainment club.
    </rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/mowl#StudentClub"/>
  </owl:Class>

  <!-- ════════════════════════════════════════════════════════════════════════
       DATA PROPERTIES - Institution Properties
  ════════════════════════════════════════════════════════════════════════ -->

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#institutionName">
    <rdfs:label xml:lang="en">institutionName</rdfs:label>
    <rdfs:comment xml:lang="en">Full official name of the institution</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/mowl#Institution"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#abbreviation">
    <rdfs:label xml:lang="en">abbreviation</rdfs:label>
    <rdfs:comment xml:lang="en">Short name or abbreviation</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#establishedYear">
    <rdfs:label xml:lang="en">establishedYear</rdfs:label>
    <rdfs:comment xml:lang="en">Year the institution was established</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#institutionType">
    <rdfs:label xml:lang="en">institutionType</rdfs:label>
    <rdfs:comment xml:lang="en">Type of institution (e.g., Deemed University, State University, Private, Central, Autonomous)</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#location">
    <rdfs:label xml:lang="en">location</rdfs:label>
    <rdfs:comment xml:lang="en">Physical location or address</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#city">
    <rdfs:label xml:lang="en">city</rdfs:label>
    <rdfs:comment xml:lang="en">City where the entity is located</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#state">
    <rdfs:label xml:lang="en">state</rdfs:label>
    <rdfs:comment xml:lang="en">State or province</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#country">
    <rdfs:label xml:lang="en">country</rdfs:label>
    <rdfs:comment xml:lang="en">Country</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#pincode">
    <rdfs:label xml:lang="en">pincode</rdfs:label>
    <rdfs:comment xml:lang="en">Postal/ZIP code</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#campusArea">
    <rdfs:label xml:lang="en">campusArea</rdfs:label>
    <rdfs:comment xml:lang="en">Total campus area (e.g., "100 acres", "50 hectares")</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#website">
    <rdfs:label xml:lang="en">website</rdfs:label>
    <rdfs:comment xml:lang="en">Official website URL</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#email">
    <rdfs:label xml:lang="en">email</rdfs:label>
    <rdfs:comment xml:lang="en">Email address</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#phone">
    <rdfs:label xml:lang="en">phone</rdfs:label>
    <rdfs:comment xml:lang="en">Contact phone number</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#fax">
    <rdfs:label xml:lang="en">fax</rdfs:label>
    <rdfs:comment xml:lang="en">Fax number</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#motto">
    <rdfs:label xml:lang="en">motto</rdfs:label>
    <rdfs:comment xml:lang="en">Official motto or tagline</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#vision">
    <rdfs:label xml:lang="en">vision</rdfs:label>
    <rdfs:comment xml:lang="en">Vision statement</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#mission">
    <rdfs:label xml:lang="en">mission</rdfs:label>
    <rdfs:comment xml:lang="en">Mission statement</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#affiliation">
    <rdfs:label xml:lang="en">affiliation</rdfs:label>
    <rdfs:comment xml:lang="en">Affiliations or recognitions (e.g., UGC, AICTE, NBA)</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#ranking">
    <rdfs:label xml:lang="en">ranking</rdfs:label>
    <rdfs:comment xml:lang="en">Overall ranking information</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <!-- ════════════════════════════════════════════════════════════════════════
       DATA PROPERTIES - Department Properties
  ════════════════════════════════════════════════════════════════════════ -->

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/mowl#departmentName">
