    <owl:Ontology rdf:about="http://www.semanticweb.org/mowl/mapping">
        <owl:imports rdf:resource="http://www.iiitb.ac.in/ontology/IIITB"/>
        <owl:imports rdf:resource="http://www.iiitd.ac.in/ontology/IIITD"/>
        <owl:imports rdf:resource="http://www.iiith.ac.in/ontology/IIITH"/>
        <owl:imports rdf:resource="http://www.semanticweb.org/mowl"/>
        <owl:imports rdf:resource="http://www.semanticweb.org/mowl#"/>
        <rdfs:comment xml:lang="en">This ontology defines the mappings from IIIT Hyderabad (h_ prefix), IIIT Bangalore (B_ prefix), and IIIT Delhi (D_ prefix) source ontologies to the Master OWL (MOWL) schema. Each source class, data property, and object property is mapped to its MOWL equivalent using owl:equivalentClass, owl:equivalentProperty, and rdfs:subClassOf relationships.</rdfs:comment>
        <rdfs:label xml:lang="en">MOWL Integration Mapping Ontology</rdfs:label>
        <owl:versionInfo>1.0</owl:versionInfo>
    </owl:Ontology>
    


